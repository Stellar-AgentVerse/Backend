# Base de datos PostgreSQL
PORT=3000
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=agentverse
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Configuración general
JWT_SECRET=change-me-in-local-dev
JWT_EXPIRES_IN=24h
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# Configuración de Stripe
STRIPE_API_KEY=sk_test_tu_api_key_aqui

# Configuración de PayPal
PAYPAL_CLIENT_ID=tu_client_id_aqui
PAYPAL_CLIENT_SECRET=tu_client_secret_aqui
PAYPAL_MODE=sandbox

# Configuración de Stellar / Soroban
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
# ID de tus contratos desplegados
SOROBAN_TOKEN_MINT_CONTRACT_ID=
SOROBAN_TOKEN_SALE_CONTRACT_ID=
# Clave privada del admin
STELLAR_ADMIN_SECRET_KEY=

# Configuración de pagos mock
MOCK_PAYMENT_ENABLED=false
MOCK_PAYMENT_FAIL=false
